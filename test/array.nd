mut array arr is [10, 10 + 10, 30]

writeLn(<arr[2]>)

string str is "Hello!"

writeLn(<str[3]>)

array grid is <GRID!(5, 5)>

writeLn(<grid>)

array row is <grid[4]>

writeLn(<row[4]>)

arr at 2 is 69

writeLn(<arr[2]>)

push(arr, 19)

writeLn(<arr>)

writeLn(<<grid[2]>[2]>)

array ex is [1, 2, 3, 4, 5]

writeLn(len(ex))

writeLn("ARRAY END")